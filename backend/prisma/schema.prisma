// Prisma schema — ExpenseHub
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum Category {
  Food
  Transport
  Housing
  Entertainment
  Healthcare
  Education
  Shopping
  Utilities
  Travel
  Other
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  category  Category
  date      DateTime
  notes     String?
  isDeleted Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
