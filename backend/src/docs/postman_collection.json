        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "    pm.environment.set(\"AUTH_TOKEN\", response.data.token);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
